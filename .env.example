# Database (SQLite default, no setup required)
DATABASE_URL=sqlite+aiosqlite:///seo_autopilot.db
# For Postgres: DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/seo

# API
API_HOST=0.0.0.0
API_PORT=8002
API_SECRET_KEY=your-super-secret-key-change-me

# Claude AI (optional — enables AI-generated fix suggestions)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Telegram (optional — enables audit notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Search Console (optional)
GSC_CREDENTIALS_PATH=./credentials/service-account.json

# PageSpeed Insights (optional — higher quota with API key)
PAGESPEED_API_KEY=

# Logging
LOG_LEVEL=INFO
